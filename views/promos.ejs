<%- include("partials/header", { title, active, mode, lastFetched }) %>

<main class="container mx-auto px-6 py-8 max-w-7xl">
  <div class="mb-6">
    <h1 class="page-title">Promotional intelligence</h1>
    <p class="page-sub">Active promos across competitors, sorted by scope (sitewide first) then end date.</p>
  </div>

  <!-- Per-competitor cards -->
  <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <% for (const c of competitors) {
         const s = summary[c] || { total: 0, scopes: {}, endingSoon: 0 };
         const isUs = c === "prospanek";
    %>
      <div class="card card-pad <%= isUs ? 'kpi-accent' : '' %>">
        <div class="kpi-label"><%= competitorLabels[c] || c %></div>
        <div class="kpi-value"><%= s.total %></div>
        <div class="kpi-foot">
          <% if (s.endingSoon) { %>
            <span class="text-brand font-semibold"><%= s.endingSoon %> ending in 7d</span>
          <% } else { %>
            <span>active promotions</span>
          <% } %>
        </div>
        <% if (Object.keys(s.scopes).length) { %>
          <div class="flex flex-wrap gap-1 mt-3">
            <% for (const [scope, n] of Object.entries(s.scopes)) { %>
              <span class="badge scope-<%= scope %>"><%= scope %> · <%= n %></span>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </section>

  <% if (promos.length === 0) { %>
    <div class="card empty">
      <div class="icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p>No active promos found in the latest snapshot.</p>
    </div>
  <% } else {
       const today = new Date();
       const soonCutoff = new Date(today.getTime() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
  %>
    <section class="card overflow-hidden">
      <div class="card-pad border-b border-line flex items-center justify-between">
        <h3>All active promos</h3>
        <div class="text-xs text-ink-mute">Rows ending within 7 days are highlighted</div>
      </div>
      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Competitor</th>
              <th>Scope</th>
              <th class="num">Discount</th>
              <th class="num">Free shipping</th>
              <th>Code</th>
              <th>Ends</th>
              <th>Promo</th>
            </tr>
          </thead>
          <tbody>
            <% for (const p of promos) {
                 const ends = p.ends_at ? String(p.ends_at).slice(0, 10) : null;
                 const endingSoon = ends && ends <= soonCutoff;
            %>
              <tr class="<%= p.competitor === 'prospanek' ? 'us-accent' : '' %> <%= endingSoon ? 'bg-brand-soft/40' : '' %>">
                <td class="competitor-cell"><%= competitorLabels[p.competitor] || p.competitor %></td>
                <td><span class="badge scope-<%= p.scope || 'product' %>"><%= p.scope || '—' %></span></td>
                <td class="num"><%= p.discount_pct ? p.discount_pct + '%' : '—' %></td>
                <td class="num"><%= p.free_shipping_threshold_czk ? Number(p.free_shipping_threshold_czk).toLocaleString("cs-CZ") + ' Kč' : '—' %></td>
                <td class="font-mono text-xs"><%= p.promo_code || '—' %></td>
                <td>
                  <% if (ends) { %>
                    <span class="<%= endingSoon ? 'text-brand font-semibold' : 'text-ink-soft' %>"><%= ends %></span>
                  <% } else { %>
                    <span class="text-ink-mute">ongoing</span>
                  <% } %>
                </td>
                <td class="max-w-md">
                  <% if (p.source_url) { %>
                    <a href="<%= p.source_url %>" target="_blank" rel="noopener" class="text-ink hover:text-brand"
                       <% if (p.promo_quote) { %>title="<%= String(p.promo_quote).replace(/"/g, '&quot;') %>"<% } %>>
                      <%= p.promo_text %>
                      <span class="text-ink-mute ml-1">↗</span>
                    </a>
                  <% } else { %>
                    <span <% if (p.promo_quote) { %>title="<%= String(p.promo_quote).replace(/"/g, '&quot;') %>"<% } %>><%= p.promo_text %></span>
                  <% } %>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>
</main>

<%- include("partials/footer") %>
