<%- include("partials/header", { title, active, mode, lastFetched }) %>

<main class="container mx-auto px-6 py-8 max-w-7xl">
  <div class="mb-6">
    <h1 class="page-title">Akce a slevy</h1>
    <p class="page-sub">Aktivní akce u konkurentů, řazené podle rozsahu (nejdříve celosíťové) a poté podle data konce.</p>
  </div>

  <!-- Per-competitor cards -->
  <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <% for (const c of competitors) {
         const s = summary[c] || { total: 0, scopes: {}, endingSoon: 0 };
         const isUs = c === "prospanek";
    %>
      <div class="card card-pad <%= isUs ? 'kpi-accent' : '' %>">
        <div class="kpi-label"><%= competitorLabels[c] || c %></div>
        <div class="kpi-value"><%= s.total %></div>
        <div class="kpi-foot">
          <% if (s.endingSoon) { %>
            <span class="text-brand font-semibold"><%= s.endingSoon %> končí do 7 dnů</span>
          <% } else { %>
            <span>aktivních akcí</span>
          <% } %>
        </div>
        <% if (Object.keys(s.scopes).length) { %>
          <div class="flex flex-wrap gap-1 mt-3">
            <% for (const [scope, n] of Object.entries(s.scopes)) { %>
              <span class="badge scope-<%= scope %>"><%= scope %> · <%= n %></span>
            <% } %>
          </div>
        <% } %>
      </div>
    <% } %>
  </section>

  <% if (promos.length === 0) { %>
    <div class="card empty">
      <div class="icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p>V poslední aktualizaci nebyly nalezeny žádné aktivní akce.</p>
    </div>
  <% } else {
       const today = new Date();
       const soonCutoff = new Date(today.getTime() + 7 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10);
       const scopes = [...new Set(promos.map(p => p.scope).filter(Boolean))];
       const promosForJs = promos.map(p => ({
         competitor: p.competitor,
         scope: p.scope || null,
         discount_pct: p.discount_pct || null,
         free_shipping_threshold_czk: p.free_shipping_threshold_czk || null,
         promo_code: p.promo_code || null,
         promo_text: p.promo_text || "",
         promo_quote: p.promo_quote || null,
         source_url: p.source_url || null,
         ends_at: p.ends_at ? String(p.ends_at).slice(0, 10) : null,
         ending_soon: !!(p.ends_at && String(p.ends_at).slice(0, 10) <= soonCutoff),
       }));
  %>
    <section class="card overflow-hidden" x-data='{
      competitor: "all",
      scope: "all",
      rows: <%- JSON.stringify(promosForJs) %>,
      competitors: <%- JSON.stringify(competitors) %>,
      competitorLabels: <%- JSON.stringify(competitorLabels) %>,
      scopes: <%- JSON.stringify(scopes) %>,
      get filtered() {
        return this.rows.filter(p =>
          (this.competitor === "all" || p.competitor === this.competitor) &&
          (this.scope === "all" || p.scope === this.scope)
        );
      }
    }'>
      <div class="card-pad border-b border-line flex items-center justify-between flex-wrap gap-2">
        <h3>Všechny aktivní akce</h3>
        <div class="text-xs text-ink-mute">Akce končící do 7 dnů jsou zvýrazněny</div>
      </div>

      <div class="card-pad border-b border-line space-y-3">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Konkurent</span>
          <button class="chip" :class="competitor==='all' ? 'active' : ''" @click="competitor='all'">Vše</button>
          <template x-for="c in competitors" :key="c">
            <button class="chip" :class="competitor===c ? 'active' : ''" @click="competitor=c" x-text="competitorLabels[c] || c"></button>
          </template>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Rozsah akce</span>
          <button class="chip" :class="scope==='all' ? 'active' : ''" @click="scope='all'">Vše</button>
          <template x-for="s in scopes" :key="s">
            <button class="chip" :class="scope===s ? 'active' : ''" @click="scope=s" x-text="s"></button>
          </template>
        </div>
      </div>

      <div class="card-pad text-xs text-ink-mute" x-text="`Zobrazeno ${filtered.length} z ${rows.length} akcí`"></div>

      <div class="overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Konkurent</th>
              <th>Rozsah</th>
              <th class="num">Sleva</th>
              <th class="num">Doprava zdarma od</th>
              <th>Kód</th>
              <th>Konec</th>
              <th>Akce</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="p in filtered" :key="p.competitor + '::' + p.promo_text">
              <tr :class="(p.competitor === 'prospanek' ? 'us-accent ' : '') + (p.ending_soon ? 'bg-brand-soft/40' : '')">
                <td class="competitor-cell" x-text="competitorLabels[p.competitor] || p.competitor"></td>
                <td><span class="badge" :class="'scope-' + (p.scope || 'product')" x-text="p.scope || '—'"></span></td>
                <td class="num" x-text="p.discount_pct ? p.discount_pct + '%' : '—'"></td>
                <td class="num" x-text="p.free_shipping_threshold_czk ? Number(p.free_shipping_threshold_czk).toLocaleString('cs-CZ') + ' Kč' : '—'"></td>
                <td class="font-mono text-xs" x-text="p.promo_code || '—'"></td>
                <td>
                  <template x-if="p.ends_at">
                    <span :class="p.ending_soon ? 'text-brand font-semibold' : 'text-ink-soft'" x-text="p.ends_at"></span>
                  </template>
                  <template x-if="!p.ends_at">
                    <span class="text-ink-mute">trvá</span>
                  </template>
                </td>
                <td class="max-w-md">
                  <template x-if="p.source_url">
                    <a :href="p.source_url" target="_blank" rel="noopener" class="text-ink hover:text-brand" :title="p.promo_quote || ''">
                      <span x-text="p.promo_text"></span>
                      <span class="text-ink-mute ml-1">↗</span>
                    </a>
                  </template>
                  <template x-if="!p.source_url">
                    <span :title="p.promo_quote || ''" x-text="p.promo_text"></span>
                  </template>
                </td>
              </tr>
            </template>
            <template x-if="filtered.length === 0">
              <tr><td colspan="7" class="text-center text-ink-mute py-6">Žádné akce neodpovídají zvoleným filtrům.</td></tr>
            </template>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>
</main>

<%- include("partials/footer") %>
