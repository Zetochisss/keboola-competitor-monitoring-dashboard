<%- include("partials/header", { title, active, mode, lastFetched }) %>

<main class="container mx-auto px-6 py-8 max-w-7xl">
  <div class="flex items-baseline justify-between flex-wrap gap-2 mb-8">
    <div>
      <h1 class="page-title">Competitor Monitoring</h1>
      <p class="page-sub"><%= today %> · 4 Czech mattress e-shops tracked daily</p>
    </div>
  </div>

  <!-- KPI cards -->
  <section class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
    <div class="card kpi-accent card-pad">
      <div class="kpi-label">Pro Spánek products</div>
      <div class="kpi-value"><%= kpi.ourProducts %></div>
      <div class="kpi-foot">tracked in latest snapshot</div>
    </div>
    <div class="card card-pad">
      <div class="kpi-label">Avg competitor</div>
      <div class="kpi-value"><%= kpi.avgCompetitor %></div>
      <div class="kpi-foot">products per competitor</div>
    </div>
    <div class="card card-pad">
      <div class="kpi-label">Active promos</div>
      <div class="kpi-value"><%= kpi.activePromos %></div>
      <div class="kpi-foot">across all competitors</div>
    </div>
    <div class="card card-pad">
      <div class="kpi-label">Services we lead on</div>
      <div class="kpi-value"><%= kpi.servicesLed %></div>
      <div class="kpi-foot">facts only Pro Spánek confirms</div>
    </div>
  </section>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Heatmap -->
    <section class="card lg:col-span-2">
      <div class="card-pad border-b border-line flex items-center justify-between">
        <div>
          <h3>Products by price segment</h3>
          <p class="text-xs text-ink-mute mt-1">Latest snapshot · all sizes</p>
        </div>
        <a href="/portfolio" class="text-sm font-medium text-brand hover:text-brand-dark">Open Portfolio →</a>
      </div>
      <div class="card-pad overflow-x-auto">
        <table class="data-table">
          <thead>
            <tr>
              <th>Segment</th>
              <% for (const c of competitors) { %>
                <th class="num <%= c === 'prospanek' ? 'us-row' : '' %>"><%= competitorLabels[c] || c %></th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% for (const seg of segments) { %>
              <tr>
                <td class="competitor-cell"><%= seg.label %></td>
                <% for (const c of competitors) {
                     const v = heatmap.matrix[seg.key][c];
                     const ratio = heatmap.max ? v / heatmap.max : 0;
                     let lvl = 0;
                     if (ratio > 0.8) lvl = 5;
                     else if (ratio > 0.6) lvl = 4;
                     else if (ratio > 0.4) lvl = 3;
                     else if (ratio > 0.2) lvl = 2;
                     else if (v > 0) lvl = 1;
                     const cls = c === "prospanek" ? `heat heat-us-${lvl}` : `heat heat-${lvl}`;
                %>
                  <td class="<%= cls %>"><%= v %></td>
                <% } %>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Insights -->
    <section class="card">
      <div class="card-pad border-b border-line">
        <h3>What's notable today</h3>
        <p class="text-xs text-ink-mute mt-1">Hand-derived signals from latest data</p>
      </div>
      <div class="card-pad">
        <% if (!insights.length) { %>
          <p class="text-sm text-ink-mute">No notable signals — data may still be loading.</p>
        <% } else { %>
          <ul class="insight-list">
            <% for (const item of insights) { %>
              <li><span class="insight-dot"></span><span><%= item %></span></li>
            <% } %>
          </ul>
        <% } %>
      </div>
    </section>
  </div>
</main>

<%- include("partials/footer") %>
