<!doctype html>
<html lang="cs">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> · Pro Spánek Competitor Monitoring</title>
  <link rel="preconnect" href="https://rsms.me/" />
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { DEFAULT: "#ef4723", dark: "#c8381a", soft: "#fff1ec" },
            ink:   { DEFAULT: "#0e1733", soft: "#4a5878", mute: "#8390ad" },
            line:  "#e4e9f4",
            soft:  "#f5f7fb",
          },
          fontFamily: {
            sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          },
          boxShadow: {
            card: '0 1px 2px rgba(14,23,51,0.03)',
          },
        },
      },
    };
  </script>
  <link rel="stylesheet" href="/style.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="font-sans">
  <header class="topbar">
    <div class="row">
      <a href="/" class="logo flex items-center gap-3">
        <img src="/img/logo.svg" alt="Pro Spánek" />
        <span class="hidden sm:inline-block text-sm font-medium text-ink-soft border-l border-line pl-3">Sledování konkurence</span>
      </a>
      <nav>
        <a href="/" class="<%= active === 'overview' ? 'active' : '' %>">Přehled</a>
        <a href="/portfolio" class="<%= active === 'portfolio' ? 'active' : '' %>">Sortiment</a>
        <a href="/services" class="<%= active === 'services' ? 'active' : '' %>">Služby</a>
        <a href="/promos" class="<%= active === 'promos' ? 'active' : '' %>">Akce</a>
        <a href="/producers" class="<%= active === 'producers' ? 'active' : '' %>">Producenti</a>
        <a href="/trends" class="<%= active === 'trends' ? 'active' : '' %>">Trendy</a>
      </nav>
      <div class="meta">
        <span class="mode-pill <%= mode %>"><%= mode %></span>
        <% if (lastFetched) { %><span class="hidden md:inline">Data: <%= lastFetched %></span><% } %>
      </div>
    </div>
  </header>
