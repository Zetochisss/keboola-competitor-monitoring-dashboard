<%- include("partials/header", { title, active, mode, lastFetched }) %>

<main class="container mx-auto px-6 py-8 max-w-7xl">
  <div class="mb-6">
    <h1 class="page-title">Trendy</h1>
    <p class="page-sub">Změny v cenách a sortimentu konkurence ze dne na den. Trendy se naplňují každým denním během.</p>
  </div>

  <!-- Novinky dne -->
  <% if (!news.items || news.items.length === 0) { %>
    <section class="card mb-6">
      <div class="card-pad border-b border-line">
        <h3>Novinky dne</h3>
        <p class="text-xs text-ink-mute mt-1">Bude k dispozici po druhém denním běhu</p>
      </div>
      <div class="empty">
        <div class="icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <p>Změny ze dne na den budou k dispozici po druhém denním běhu extraktoru.</p>
      </div>
    </section>
  <% } else { %>
    <section class="card mb-6" x-data='{
      competitor: "competitors",
      direction: "all",
      type: "all",
      rows: <%- JSON.stringify(news.items) %>,
      competitors: <%- JSON.stringify(competitors) %>,
      competitorLabels: <%- JSON.stringify(competitorLabels) %>,
      typeLabel(t) { return t === "price_changed" ? "Cena" : (t === "new_product" ? "Nový" : "Odebrán"); },
      sevClass(s) { return s === "high" ? "badge-no" : (s === "medium" ? "badge-num" : "badge-yes"); },
      fmt(n) { return n == null ? "—" : Math.round(Number(n)).toLocaleString("cs-CZ") + " Kč"; },
      get filtered() {
        return this.rows.filter(e => {
          if (this.competitor === "competitors" && e.competitor === "prospanek") return false;
          if (this.competitor === "prospanek" && e.competitor !== "prospanek") return false;
          if (this.competitor !== "all" && this.competitor !== "competitors" && this.competitor !== "prospanek" && e.competitor !== this.competitor) return false;
          if (this.type !== "all" && e.event_type !== this.type) return false;
          if (this.direction === "up" && !(e.pct_change != null && Number(e.pct_change) > 0)) return false;
          if (this.direction === "down" && !(e.pct_change != null && Number(e.pct_change) < 0)) return false;
          return true;
        });
      }
    }'>
      <div class="card-pad border-b border-line flex items-center justify-between flex-wrap gap-2">
        <div>
          <h3>Novinky dne</h3>
          <p class="text-xs text-ink-mute mt-1">
            <% if (newsDateLabel) { %>Změny zjištěné <%= newsDateLabel %> oproti předchozí aktualizaci<% } %>
          </p>
        </div>
        <div class="flex gap-2 text-xs">
          <% if (news.totals.price > 0) { %><span class="badge scope-sitewide"><%= news.totals.price %> změn cen</span><% } %>
          <% if (news.totals.new > 0) { %><span class="badge scope-product"><%= news.totals.new %> nových</span><% } %>
          <% if (news.totals.removed > 0) { %><span class="badge scope-bundle"><%= news.totals.removed %> odebraných</span><% } %>
        </div>
      </div>

      <div class="card-pad border-b border-line space-y-3">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Konkurent</span>
          <button class="chip" :class="competitor==='competitors' ? 'active' : ''" @click="competitor='competitors'">Pouze konkurence</button>
          <button class="chip" :class="competitor==='all' ? 'active' : ''" @click="competitor='all'">Vše vč. Pro Spánku</button>
          <button class="chip" :class="competitor==='prospanek' ? 'active' : ''" @click="competitor='prospanek'">Pouze Pro Spánek</button>
          <span class="text-ink-mute mx-1">|</span>
          <template x-for="c in competitors.filter(x => x !== 'prospanek')" :key="c">
            <button class="chip" :class="competitor===c ? 'active' : ''" @click="competitor=c" x-text="competitorLabels[c] || c"></button>
          </template>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Typ změny</span>
          <button class="chip" :class="type==='all' ? 'active' : ''" @click="type='all'">Vše</button>
          <button class="chip" :class="type==='price_changed' ? 'active' : ''" @click="type='price_changed'">Změny cen</button>
          <button class="chip" :class="type==='new_product' ? 'active' : ''" @click="type='new_product'">Nové produkty</button>
          <button class="chip" :class="type==='removed_product' ? 'active' : ''" @click="type='removed_product'">Odebrané</button>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Směr ceny</span>
          <button class="chip" :class="direction==='all' ? 'active' : ''" @click="direction='all'">Vše</button>
          <button class="chip" :class="direction==='up' ? 'active' : ''" @click="direction='up'">↑ Zdražení</button>
          <button class="chip" :class="direction==='down' ? 'active' : ''" @click="direction='down'">↓ Zlevnění</button>
        </div>
      </div>

      <div class="card-pad text-xs text-ink-mute" x-text="`Zobrazeno ${filtered.length} z ${rows.length} změn`"></div>

      <div class="overflow-x-auto" style="max-height: 600px; overflow-y: auto;">
        <table class="data-table">
          <thead>
            <tr>
              <th>Typ</th>
              <th>Konkurent</th>
              <th>Produkt</th>
              <th>Rozměr</th>
              <th class="num">Z</th>
              <th class="num">Na</th>
              <th class="num">Změna</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="e in filtered" :key="e.competitor + '::' + e.source_url + '::' + e.size + '::' + e.event_type">
              <tr :class="e.competitor === 'prospanek' ? 'us-accent' : ''">
                <td><span class="badge" :class="sevClass(e.severity)" x-text="typeLabel(e.event_type)"></span></td>
                <td class="competitor-cell" x-text="competitorLabels[e.competitor] || e.competitor"></td>
                <td>
                  <template x-if="e.source_url">
                    <a :href="e.source_url" target="_blank" rel="noopener" class="font-medium" x-text="e.name || '(bez názvu)'"></a>
                  </template>
                  <template x-if="!e.source_url">
                    <span class="font-medium" x-text="e.name || '(bez názvu)'"></span>
                  </template>
                </td>
                <td class="text-ink-soft" x-text="e.size"></td>
                <td class="num text-ink-mute" x-text="fmt(e.old_value)"></td>
                <td class="num font-semibold" x-text="fmt(e.new_value)"></td>
                <td class="num">
                  <template x-if="e.pct_change != null">
                    <span :class="Number(e.pct_change) < 0 ? 'text-brand font-semibold' : 'text-ink'"
                          x-text="(Number(e.pct_change) > 0 ? '+' : '') + Number(e.pct_change).toLocaleString('cs-CZ') + ' %'"></span>
                  </template>
                  <template x-if="e.pct_change == null">
                    <span class="text-ink-mute">—</span>
                  </template>
                </td>
              </tr>
            </template>
            <template x-if="filtered.length === 0">
              <tr><td colspan="7" class="text-center text-ink-mute py-6">Žádné změny neodpovídají zvoleným filtrům.</td></tr>
            </template>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>

  <!-- Vývoj cen v čase -->
  <section class="card">
    <div class="card-pad border-b border-line">
      <h3>Vývoj mediánové ceny v čase</h3>
      <p class="text-xs text-ink-mute mt-1">Rozměr 180×200 · medián efektivní ceny per konkurent · čára se prodlužuje s každým denním během</p>
    </div>
    <div class="card-pad" style="height: 360px;">
      <% if (!trend.dates || trend.dates.length < 2) { %>
        <div class="empty">
          <div class="icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <p>Trendová křivka se zobrazí po druhém denním běhu extraktoru. Aktuálně máme <%= (trend.dates || []).length %> aktualizaci.</p>
        </div>
      <% } else { %>
        <canvas id="chart-trend"></canvas>
      <% } %>
    </div>
  </section>
</main>

<script>
  (function() {
    const BRAND = '#ef4723';
    const GREYS = ['#94a3b8', '#cbd5e1', '#64748b'];
    const competitors = <%- JSON.stringify(competitors) %>;
    const labels = <%- JSON.stringify(competitors.map(c => competitorLabels[c] || c)) %>;
    const trend = <%- JSON.stringify(trend) %>;

    const ctx = document.getElementById('chart-trend');
    if (ctx && trend.dates && trend.dates.length >= 2) {
      const fmtDate = (iso) => {
        const [y, m, d] = iso.split('-').map(Number);
        return new Date(y, m - 1, d).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'short' });
      };
      let greyIdx = 0;
      const datasets = competitors.map((c, i) => {
        const isUs = c === 'prospanek';
        const color = isUs ? BRAND : GREYS[greyIdx++ % GREYS.length];
        return {
          label: labels[i],
          data: trend.series[c],
          borderColor: color,
          backgroundColor: isUs ? 'rgba(239, 71, 35, 0.10)' : 'transparent',
          fill: isUs,
          tension: 0.25,
          borderWidth: isUs ? 2.5 : 1.5,
          pointRadius: 3,
          pointHoverRadius: 5,
          spanGaps: true,
        };
      });
      new Chart(ctx, {
        type: 'line',
        data: { labels: trend.dates.map(fmtDate), datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 10, boxHeight: 10, font: { family: 'Inter', size: 11 } } },
            tooltip: { padding: 10, callbacks: {
              label: (ctx) => `${ctx.dataset.label}: ${ctx.parsed.y == null ? '—' : Math.round(ctx.parsed.y).toLocaleString('cs-CZ') + ' Kč'}`,
            } },
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 10 } } },
            y: { grid: { color: '#e4e9f4' }, ticks: { font: { family: 'Inter', size: 10 }, callback: (v) => Math.round(v).toLocaleString('cs-CZ') + ' Kč' } },
          },
        },
      });
    }
  })();
</script>

<%- include("partials/footer") %>
