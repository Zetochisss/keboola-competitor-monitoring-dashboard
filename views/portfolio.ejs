<%- include("partials/header", { title, active, mode, lastFetched }) %>

<main class="container mx-auto px-6 py-8 max-w-7xl">
  <div class="mb-6">
    <h1 class="page-title">Sortiment</h1>
    <p class="page-sub">Počty produktů, cenové rozložení a nejdražší produkty u jednotlivých konkurentů.</p>
  </div>

  <!-- Filter bar -->
  <section class="card card-pad mb-6">
    <form method="get" action="/portfolio" class="filterbar" id="filter-form">
      <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-2">Rozměr</span>
      <% const sizeOpts = [{key:"all",label:"Všechny rozměry"}, {key:"90x200",label:"90×200"}, {key:"160x200",label:"160×200"}, {key:"180x200",label:"180×200"}]; %>
      <% for (const opt of sizeOpts) { %>
        <label class="chip <%= size === opt.key ? 'active' : '' %>">
          <input type="radio" name="size" value="<%= opt.key %>" class="hidden" <%= size === opt.key ? 'checked' : '' %> onchange="document.getElementById('filter-form').submit()" />
          <%= opt.label %>
        </label>
      <% } %>
    </form>
  </section>

  <!-- Charts row -->
  <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
    <div class="card">
      <div class="card-pad border-b border-line">
        <h3>Produkty v segmentu</h3>
        <p class="text-xs text-ink-mute mt-1">Sčítáno podle konkurenta</p>
      </div>
      <div class="card-pad" style="height: 320px;">
        <canvas id="chart-segments"></canvas>
      </div>
    </div>
    <div class="card">
      <div class="card-pad border-b border-line">
        <h3>Rozložení cen</h3>
        <p class="text-xs text-ink-mute mt-1">Pásma 2 500 Kč, počet produktů</p>
      </div>
      <div class="card-pad" style="height: 320px;">
        <canvas id="chart-histogram"></canvas>
      </div>
    </div>
  </section>

  <!-- Browseable product list -->
  <section class="card" x-data='{
    view: "top",
    competitor: "all",
    availability: "all",
    rows: <%- JSON.stringify(ranked) %>,
    competitors: <%- JSON.stringify(competitors) %>,
    competitorLabels: <%- JSON.stringify(competitorLabels) %>,
    fmt(n) { return n == null ? "—" : Math.round(n).toLocaleString("cs-CZ") + " Kč"; },
    get filtered() {
      let r = this.rows;
      if (this.competitor !== "all") r = r.filter(x => x.competitor === this.competitor);
      if (this.availability === "in") r = r.filter(x => x.is_available === true);
      if (this.availability === "out") r = r.filter(x => x.is_available === false);
      if (this.view === "top") return r.slice(0, 10);
      if (this.view === "bottom") return r.slice(-10).reverse();
      return r;
    }
  }'>
    <div class="card-pad border-b border-line">
      <h3>Procházení produktů</h3>
      <p class="text-xs text-ink-mute mt-1"><%= size === "all" ? "Všechny rozměry" : "Rozměr " + size %> · poslední aktualizace</p>
    </div>

    <div class="card-pad border-b border-line space-y-3">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Pohled</span>
        <button class="chip" :class="view==='top' ? 'active' : ''" @click="view='top'">Top 10 nejdražších</button>
        <button class="chip" :class="view==='all' ? 'active' : ''" @click="view='all'">Všechny produkty</button>
        <button class="chip" :class="view==='bottom' ? 'active' : ''" @click="view='bottom'">10 nejlevnějších</button>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Konkurent</span>
        <button class="chip" :class="competitor==='all' ? 'active' : ''" @click="competitor='all'">Vše</button>
        <template x-for="c in competitors" :key="c">
          <button class="chip" :class="competitor===c ? 'active' : ''" @click="competitor=c" x-text="competitorLabels[c] || c"></button>
        </template>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs uppercase tracking-wider text-ink-mute font-medium mr-1">Dostupnost</span>
        <button class="chip" :class="availability==='all' ? 'active' : ''" @click="availability='all'">Vše</button>
        <button class="chip" :class="availability==='in' ? 'active' : ''" @click="availability='in'">Skladem</button>
        <button class="chip" :class="availability==='out' ? 'active' : ''" @click="availability='out'">Nedostupné</button>
      </div>
    </div>

    <div class="card-pad text-xs text-ink-mute" x-text="`Zobrazeno ${filtered.length} ${filtered.length === 1 ? 'produkt' : (filtered.length >= 2 && filtered.length <= 4 ? 'produkty' : 'produktů')}`"></div>

    <div class="overflow-x-auto" style="max-height: 600px; overflow-y: auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th class="w-10">#</th>
            <th>Produkt</th>
            <th>Konkurent</th>
            <th>Producent</th>
            <th>Rozměr</th>
            <th>Podkategorie</th>
            <th>Dostupnost</th>
            <th class="num">Cena</th>
          </tr>
        </thead>
        <tbody>
          <template x-for="(p, idx) in filtered" :key="p.competitor + '::' + p.source_url + '::' + p.size">
            <tr :class="p.competitor === 'prospanek' ? 'us-accent' : ''">
              <td class="text-ink-mute" x-text="idx + 1"></td>
              <td>
                <template x-if="p.source_url">
                  <a :href="p.source_url" target="_blank" rel="noopener" class="font-medium" x-text="p.name || '(bez názvu)'"></a>
                </template>
                <template x-if="!p.source_url">
                  <span class="font-medium" x-text="p.name || '(bez názvu)'"></span>
                </template>
              </td>
              <td class="competitor-cell" x-text="competitorLabels[p.competitor] || p.competitor"></td>
              <td class="text-ink-soft" x-text="p.brand || '—'"></td>
              <td class="text-ink-soft" x-text="p.size"></td>
              <td class="text-ink-soft" x-text="p.subcategory || '—'"></td>
              <td>
                <template x-if="p.is_available === true">
                  <span class="badge badge-yes">Skladem</span>
                </template>
                <template x-if="p.is_available === false">
                  <span class="badge badge-no">Nedostupné</span>
                </template>
                <template x-if="p.is_available == null">
                  <span class="text-ink-mute">—</span>
                </template>
              </td>
              <td class="num font-semibold" x-text="fmt(p.price)"></td>
            </tr>
          </template>
          <template x-if="filtered.length === 0">
            <tr><td colspan="8" class="text-center text-ink-mute py-6">Žádné produkty neodpovídají zvoleným filtrům.</td></tr>
          </template>
        </tbody>
      </table>
    </div>
  </section>
</main>

<script>
  (function() {
    const BRAND = '#ef4723';
    const GREYS = ['#94a3b8', '#cbd5e1', '#64748b'];
    const competitors = <%- JSON.stringify(competitors) %>;
    const labels = <%- JSON.stringify(competitors.map(c => competitorLabels[c] || c)) %>;
    const segments = <%- JSON.stringify(segments.map(s => s.label)) %>;
    const matrix = <%- JSON.stringify(matrix) %>;
    const segKeys = <%- JSON.stringify(segments.map(s => s.key)) %>;

    // Stacked bar: per-segment, per-competitor.
    const segCtx = document.getElementById('chart-segments');
    if (segCtx) {
      let greyIdx = 0;
      const datasets = competitors.map((c, i) => ({
        label: labels[i],
        data: segKeys.map(k => matrix[k][c]),
        backgroundColor: c === 'prospanek' ? BRAND : GREYS[greyIdx++ % GREYS.length],
        borderRadius: 4,
        borderWidth: 0,
      }));
      new Chart(segCtx, {
        type: 'bar',
        data: { labels: segments, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 10, boxHeight: 10, font: { family: 'Inter', size: 11 } } },
            tooltip: { padding: 10 },
          },
          scales: {
            x: { stacked: true, grid: { display: false }, ticks: { font: { family: 'Inter', size: 10 } } },
            y: { stacked: true, grid: { color: '#e4e9f4' }, ticks: { font: { family: 'Inter', size: 10 } } },
          },
        },
      });
    }

    // Histogram: line/area per competitor.
    const histCtx = document.getElementById('chart-histogram');
    const hist = <%- JSON.stringify(hist) %>;
    if (histCtx) {
      let greyIdx = 0;
      const datasets = competitors.map((c, i) => {
        const isUs = c === 'prospanek';
        const color = isUs ? BRAND : GREYS[greyIdx++ % GREYS.length];
        return {
          label: labels[i],
          data: hist.series[c],
          borderColor: color,
          backgroundColor: isUs ? 'rgba(239, 71, 35, 0.15)' : 'rgba(148, 163, 184, 0.08)',
          fill: isUs,
          tension: 0.3,
          borderWidth: isUs ? 2.5 : 1.5,
          pointRadius: 0,
          pointHoverRadius: 4,
        };
      });
      new Chart(histCtx, {
        type: 'line',
        data: { labels: hist.labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { position: 'bottom', labels: { boxWidth: 10, boxHeight: 10, font: { family: 'Inter', size: 11 } } },
            tooltip: { padding: 10, callbacks: { title: (i) => 'Pásmo ' + i[0].label + ' Kč' } },
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 10 } } },
            y: { grid: { color: '#e4e9f4' }, ticks: { font: { family: 'Inter', size: 10 } } },
          },
        },
      });
    }
  })();
</script>

<%- include("partials/footer") %>
